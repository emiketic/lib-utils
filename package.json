{
  "name": "@emiketic/lib-utils",
  "version": "1.0.1",
  "description": "Shared utility functions: validation, color, image, JWT, phone, navigation, and more",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.mjs",
      "require": "./dist/server.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.mjs",
      "require": "./dist/client.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "chroma-js": "^2.4.2",
    "formdata-node": "^6.0.3",
    "jsonwebtoken": "^9.0.2",
    "libphonenumber-js": "^1.11.0"
  },
  "devDependencies": {
    "@types/chroma-js": "^2.4.4",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "@mantine/core": ">=7.0.0",
    "next": ">=14.0.0",
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "@mantine/core": {
      "optional": true
    },
    "next": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "utils",
    "validation",
    "color",
    "image",
    "jwt",
    "phone",
    "navigation",
    "typescript"
  ],
  "license": "MIT",
  "author": {
    "name": "EMIKETIC Technologies",
    "email": "contact@emiketic.com",
    "url": "https://www.emiketic.com"
  }
}
